# LM Studio: Developer tab → Start server (default port 1234)
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Exact id from GET http://127.0.0.1:1234/v1/models in LM Studio
LM_STUDIO_MODEL=openai/gpt-oss-20b

PORT=3004
HOST=0.0.0.0

# Required for /api/chat (browser will get a JWT from a future Vercel /api/mac-token).
# When Auth.js is added, set this to the exact same string as NEXTAUTH_SECRET on Vercel.
AUTH_SECRET=

# JWT claims (must match whatever mints the Bearer token)
JWT_ISSUER=yanylevin-next
JWT_AUDIENCE=yanylevin-mac-api

# Optional CORS allowlist (comma-separated)
# ALLOWED_ORIGINS=https://yanylevin.com,https://www.yanylevin.com,http://localhost:8080
