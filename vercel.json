{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/data/(.*)", "destination": "/data/$1" }
  ],
  "headers": [
    {
      "source": "/runtime-config.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
